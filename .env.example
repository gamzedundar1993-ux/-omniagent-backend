# Anthropic API key — https://console.anthropic.com/settings/keys
# Required: the chatbot calls Claude via this key. Server-side only — never expose in client JS.
ANTHROPIC_API_KEY=

# Claude model to use for chat. Defaults to claude-sonnet-4-6 if unset.
# Options: claude-sonnet-4-6 (recommended), claude-opus-4-7 (more capable, slower/pricier), claude-haiku-4-5-20251001 (cheapest/fastest)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Server port (optional, defaults to 3000)
PORT=3000

# Allowed origins for the embeddable widget (comma-separated, no spaces).
# For local dev, leave empty to allow all origins. In production set to the
# broker domains that have embedded the widget, e.g. https://broker1.com,https://broker2.com
WIDGET_ALLOWED_ORIGINS=

# ---- Google Calendar OAuth ----
# Required for the appointment scheduling module. Create a Web Application
# OAuth client at https://console.cloud.google.com/apis/credentials and add
# the redirect URI below to its "Authorized redirect URIs" list.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback

# 32-byte (64 hex char) key used to encrypt OAuth refresh tokens at rest.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Treat this like a database password — losing it means re-connecting every broker calendar.
TOKEN_ENCRYPTION_KEY=

# ---- Twilio SMS ----
# Required for the property-matching auto-SMS alerts (Module 3) and appointment
# reminders. Without these, notifier.js logs a simulated SMS instead of sending.
# Get credentials from https://console.twilio.com/ → Account → API keys & tokens.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio phone number that SMS messages are sent FROM. Must be E.164 format
# (e.g. +15551234567) and provisioned in your Twilio account.
TWILIO_FROM_NUMBER=

# Public base URL of THIS server, used to validate inbound Twilio webhooks
# (POST /api/sms/webhook). Without it, signature validation is skipped — fine
# for local dev, but in production set this to your real https:// origin.
# Example: https://api.yourbrokerdomain.com
TWILIO_WEBHOOK_BASE_URL=

# ---- Dashboard authentication ----
# The broker dashboard and its data endpoints expose customer PII (lead names,
# emails, phones, chat transcripts) and can trigger SMS. Set DASHBOARD_PASSWORD
# to require HTTP Basic Auth in front of the dashboard. When left BLANK the
# dashboard is fully PUBLIC (anyone with the URL can read data / trigger SMS)
# and the server prints a security warning on startup — set this in production.
# Public surfaces stay open regardless: /widget.js, /api/chat/*, the Twilio
# webhook, the Google OAuth round-trip, and /api/health.
DASHBOARD_USER=broker
DASHBOARD_PASSWORD=

# ---- Demo data ----
# When set to "true", the server seeds a curated demo dataset on startup IF the
# database is empty (8 Miami/FL listings, 3 leads across HOT/WARM/COLD tiers, a
# conversation transcript, a pending appointment, property tracks, a follow-up).
# Useful for sales demos and on ephemeral hosts where the DB resets on restart.
# WARNING: seeding first wipes all operational data — never enable on a
# production instance holding real customer data. Leave blank/false in prod.
SEED_DEMO=

# ---- Data persistence ----
# Absolute path to the SQLite database file. Defaults to server/data.db next to
# the code. On hosts with EPHEMERAL disks (e.g. Render without a persistent
# disk), that default is wiped on every deploy/restart — meaning real leads and
# appointments are LOST. In production, attach a persistent disk and point this
# at a path on it, e.g. DATA_DB_PATH=/var/data/data.db
DATA_DB_PATH=

# ---- Chatbot Identity ----
# The name of the real estate company the chatbot represents.
COMPANY_NAME=
# The name of the virtual assistant chatbot.
ASSISTANT_NAME=

